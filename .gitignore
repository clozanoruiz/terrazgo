# Rust / Cargo build output
/target/
**/target/
**/*.rs.bk
*.pdb

# Tauri generated schemas (the Android project under gen/android IS tracked:
# manifest, icons and permission edits are source; its own .gitignore keeps
# Gradle build output and keystores out)
/src-tauri/gen/schemas/

# Editor / OS noise
.DS_Store
*.swp
.idea/
.vscode/*
!.vscode/extensions.json

# Local SQLite databases (regulatory data must never be committed)
*.sqlite
*.sqlite3
*.db
*.db-wal
*.db-shm

# Frontend toolchain
/node_modules/
/dist/


# Local task-research material (specs, extracted docs) — never committed;
# manifest in .taskdocs/<task>/README.md; delete the folder when the task ships
/.taskdocs/
